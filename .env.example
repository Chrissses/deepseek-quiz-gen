# ============================================================
# DeepSeek Quiz Generator — 多 AI 厂商配置
# ============================================================
# 将需要使用的厂商的 API Key 取消注释并填入实际值。
# 未配置 API Key 的厂商会自动被跳过。
# 详细厂商列表参见 providers.json。
# ============================================================

# ── DeepSeek（默认） ──────────────────────────────
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── OpenAI ─────────────────────────────────────────
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 通义千问 (Alibaba Qwen) ────────────────────────
# QWEN_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 智谱 GLM (Zhipu) ───────────────────────────────
# ZHIPU_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Moonshot / Kimi ────────────────────────────────
# MOONSHOT_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Anthropic Claude ───────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Google Gemini ──────────────────────────────────
# GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
